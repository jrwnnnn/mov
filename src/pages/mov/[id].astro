---
Astro.response.headers.set("Cache-Control", "public, max-age=60");

import { env } from "cloudflare:workers";
import Layout from "../../layouts/Layout.astro";

const id = Astro.params.id;
const result = await env.DB.prepare("SELECT * FROM movs WHERE id = ?")
	.bind(id)
	.all();
---

{
	result.results.map((mov) => (
		<Layout
			title={`MOV Shot - ${new Date(mov.date as string).toLocaleDateString()}`}
			description={mov.narrative}
		>
			<main class="min-h-screen bg-linear-to-br from-[#f5f5ff] via-[#e3e9fc] to-[#f0f4ff] p-5 md:p-10">
				<article class="mx-auto flex max-w-4xl flex-col space-y-6 rounded-3xl border border-gray-100 bg-white/90 px-5 py-8 shadow-xl md:px-12 md:py-15">
					<a
						href="/"
						class="text-md font-medium text-black/40 hover:text-black/60"
						data-astro-prefeth
					>
						&larr; Back to HomePage
					</a>

					<h1 class="text-3xl font-extrabold tracking-tight text-gray-900 drop-shadow-sm md:text-5xl">
						{new Date(mov.date as string).toLocaleDateString("en-US", {
							timeZone: "UTC",
							month: "long",
							day: "numeric",
							year: "numeric",
						})}
					</h1>

					<p class="text-base leading-relaxed text-gray-700 md:text-lg">
						{mov.narrative}
					</p>

					<div class="flex flex-wrap gap-2">
						<span class="rounded-full bg-blue-600/90 px-4 py-1.5 text-sm font-medium text-white shadow-md">
							Recitation: {mov.recitationScore ?? "N/A"}
						</span>
						<span class="rounded-full bg-amber-500/90 px-4 py-1.5 text-sm font-medium text-white shadow-md">
							Written Work: {mov.writtenWorksScore ?? "N/A"}
						</span>
					</div>

					<img
						src={`https://r2.mov.jrwnnnn.me/${mov.photo_1}`}
						alt="Photo OP 1"
						class="images"
					/>
					<img
						src={`https://r2.mov.jrwnnnn.me/${mov.photo_2}`}
						alt="Photo OP 2"
						class="images"
					/>
					{mov.photo_extra && (
						<img
							src={`https://r2.mov.jrwnnnn.me/${mov.photo_extra}`}
							alt="Extra image"
							class="images"
						/>
					)}
				</article>
			</main>
		</Layout>
	))
}

<style is:global>
	@reference "../../styles/global.css";

	.images {
		@apply w-full rounded-lg object-cover;
	}
</style>
